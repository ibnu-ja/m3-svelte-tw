root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
ij_yaml_line_comment_at_first_column = false
ij_yaml_keep_line_breaks = true
ij_yaml_spaces_within_braces = true
ij_yaml_spaces_within_brackets = true

[*.svelte]
tab_width = 2
ij_continuation_indent_size = 2
ij_typescript_spaces_within_imports = true
ij_javascript_spaces_within_imports = true

[{*.ats,*.cts,*.mts,*.ts}]
ij_continuation_indent_size = 4
ij_typescript_block_comment_at_first_column = false
ij_typescript_line_comment_at_first_column = false
ij_typescript_line_comment_add_space = true
ij_typescript_space_before_type_colon = false
ij_typescript_space_after_type_colon = true
ij_typescript_use_double_quotes = true
ij_typescript_use_semicolon_after_statement = true
ij_typescript_force_semicolon_style = false
ij_typescript_enforce_trailing_comma = keep
ij_typescript_spaces_within_imports = true

[{*.cjs,*.es6,*.js,*.mjs}]
ij_continuation_indent_size = 4
ij_javascript_block_comment_at_first_column = false
ij_javascript_line_comment_at_first_column = false
ij_javascript_line_comment_add_space = true
ij_javascript_space_before_property_colon = false
ij_javascript_space_after_property_colon = true
ij_javascript_use_double_quotes = true
ij_javascript_use_semicolon_after_statement = true
ij_javascript_force_semicolon_style = false
ij_javascript_enforce_trailing_comma = keep
ij_javascript_spaces_within_imports = true

[{*.json,*.jsonc}]
ij_json_space_after_colon = true
ij_json_space_after_comma = true
ij_json_keep_trailing_comma = false

[*.css]
ij_css_brace_placement = end_of_line
ij_css_space_before_opening_brace = true
ij_css_space_after_colon = true
ij_css_use_double_quotes = true

[*.less]
ij_less_line_comment_at_first_column = false
ij_less_brace_placement = end_of_line
ij_less_space_before_opening_brace = true

[*.sass]
ij_sass_line_comment_at_first_column = false
ij_sass_brace_placement = end_of_line

[*.scss]
ij_scss_line_comment_at_first_column = false
ij_scss_brace_placement = end_of_line
ij_scss_space_before_opening_brace = true

[{*.htm,*.html,*.sht,*.shtm,*.shtml}]
ij_html_block_comment_at_first_column = false
ij_html_line_comment_at_first_column = false
ij_html_quote_style = double

[{*.ant,*.fxml,*.jhm,*.jnlp,*.jrxml,*.rng,*.tld,*.ui,*.wsdd,*.wsdl,*.xjb,*.xml,*.xsd,*.xsl,*.xslt,*.xul,phpunit.xml.dist}]
ij_xml_block_comment_at_first_column = false
ij_xml_line_comment_at_first_column = false
